# ─── Base44 (frontend runtime) ────────────────────────────────────────────────
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=

# ─── Core deployment ───────────────────────────────────────────────────────────
# Public app origin used for auth cookie domains, invite links, and live self-checks.
APP_URL=
# Random 32-byte hex secret for HMAC session cookie signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SIGNING_SECRET=
# Optional dedicated secret for hashing issued NexusUser auth keys.
# If omitted, key hashing falls back to SESSION_SIGNING_SECRET.
AUTH_KEY_HASH_SECRET=
# Optional comma- or newline-separated legacy key-hash secrets kept during migration.
AUTH_KEY_HASH_FALLBACK_SECRETS=
# Emergency recovery secret for the fixed system-admin account.
SYSTEM_ADMIN_BOOTSTRAP_SECRET=

# ─── External integrations ────────────────────────────────────────────────────
UEX_API_KEY=
SC_API_KEY=
FLEETYARDS_HANDLE=
VITE_UEX_API_URL=https://uexcorp.space/api/2.0
UEX_API_URL=https://uexcorp.space/api/2.0
VITE_STARHEAD_API_URL=https://api.star-citizen.wiki/api/v2
STARHEAD_API_URL=https://api.star-citizen.wiki/api/v2

# ─── Live proof harness ────────────────────────────────────────────────────────
E2E_BASE_URL=
E2E_ADMIN_USERNAME=
E2E_ADMIN_KEY=
# Optional if the live proof needs to recover or bootstrap the admin account.
E2E_BOOTSTRAP_SECRET=
