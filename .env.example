# ─── Base44 (injected by host at runtime) ─────────────────────────────────────
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=

# ─── App URL ───────────────────────────────────────────────────────────────────
# Full origin of the deployed app — used by auth functions for cookie domain
# and redirect resolution. Example: https://yourapp.base44.app
APP_URL=

# ─── Discord OAuth ─────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match the redirect URI registered in Discord Developer Portal exactly.
# Format: {APP_URL}/functions/auth/discord/callback
DISCORD_REDIRECT_URI=

# ─── Discord Bot + Guild ──────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# Redscar Nomads Discord server ID (Settings → Widget → Server ID)
DISCORD_GUILD_ID=

# ─── Session signing ───────────────────────────────────────────────────────────
# Random 32-byte hex secret for HMAC session cookie signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SIGNING_SECRET=

# ─── Discord channel IDs ──────────────────────────────────────────────────────
NEXUSOS_OPS_CHANNEL_ID=
NEXUSOS_OCR_CHANNEL_ID=
NEXUSOS_INTEL_CHANNEL_ID=
NEXUSOS_LOG_CHANNEL_ID=
ARMORY_CHANNEL_ID=
COFFER_CHANNEL_ID=
INVOICES_CHANNEL_ID=
INDUSTRY_CHANNEL_ID=
RANGERS_CHANNEL_ID=
ANNOUNCEMENTS_CHANNEL_ID=
PTU_CHANNEL_ID=
BONFIRE_CHANNEL_ID=
REDSCAR_ONLY_CHANNEL_ID=

# ─── External APIs ────────────────────────────────────────────────────────────
SC_API_KEY=
UEX_API_KEY=
VITE_UEX_API_URL=https://uexcorp.space/api/2.0
UEX_API_URL=https://uexcorp.space/api/2.0
VITE_STARHEAD_API_URL=https://api.star-citizen.wiki/api/v2
STARHEAD_API_URL=https://api.star-citizen.wiki/api/v2

# ─── Demo mode ─────────────────────────────────────────────────────────────────
# Set to true during local dev to use mock personas instead of Discord OAuth.
VITE_DEMO_MODE=false

# ─── Collaboration sandbox frontend ────────────────────────────────────────────
# Enable for the dedicated GitHub/Vercel collaboration deployment.
VITE_TEMP_ACCESS_MODE=false
# "shared" uses /api/demo/* and shared preview state. "local" keeps in-browser mocks.
VITE_SANDBOX_MODE=shared
# Optional override for demo API origin. Leave blank for same-origin Vercel previews.
VITE_SANDBOX_API_BASE=

# ─── Collaboration sandbox backend (Vercel) ───────────────────────────────────
# Shared preview namespace and seed version for the demo sandbox reset flow.
DEMO_SANDBOX_NAMESPACE=default
DEMO_SANDBOX_SEED_VERSION=v1
# Optional: Vercel KV / Upstash-compatible credentials for shared writable state.
# Without these, /api/demo/* falls back to in-memory state and is not durable.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_READ_ONLY_URL=
KV_URL=
